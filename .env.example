# Copy to .env and adjust if needed: cp .env.example .env
# Used by Makefile and backend (ALPHA-001+). Do not commit .env.

# PostgreSQL (matches docker-compose.yml defaults)
POSTGRES_USER=herogame
POSTGRES_PASSWORD=herogame
POSTGRES_DB=herogame
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Application connection strings (host = localhost when using published ports)
DATABASE_URL=postgres://herogame:herogame@localhost:5432/herogame?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# Backend HTTP (ALPHA-001)
HTTP_ADDR=:8080

# Run goose migrations on server start when DATABASE_URL is set (default on; set 0 to disable)
RUN_MIGRATIONS=1
